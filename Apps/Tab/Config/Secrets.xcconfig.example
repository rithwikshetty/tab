// Copy this file to Apps/Tab/Config/Secrets.xcconfig and fill in local values.
// Do not commit Secrets.xcconfig.

TAB_BUNDLE_ID = com.example.tab
TAB_AUTH_CALLBACK_SCHEME = $(TAB_BUNDLE_ID)
TAB_SUPABASE_URL = https:/$()/your-project-ref.supabase.co
TAB_SUPABASE_PUBLISHABLE_KEY = your-supabase-publishable-key
TAB_DEVELOPMENT_TEAM = YOUR_TEAM_ID
TAB_TURNSTILE_SITE_KEY = your-turnstile-site-key
